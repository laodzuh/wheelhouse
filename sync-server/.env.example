# Shared secret the client sends as: Authorization: Bearer <SYNC_SECRET>
# Generate with: openssl rand -base64 32
SYNC_SECRET=

# Port to bind on 127.0.0.1. Tailscale serve is the only path in from the tailnet.
PORT=8787

# Comma-separated list of origins allowed to call the sync endpoint via CORS.
# Include the Wheelhouse production URL and any local dev origin you use.
ALLOWED_ORIGINS=https://wheelhouse-app.netlify.app,http://localhost:5173

# Directory for the stored blob.
DATA_DIR=./data
